<launch>
  <!-- UWB/IMU 확인 전용. /cmd_vel을 내는 LiDAR planner를 켜지 않는다. -->
  <arg name="tag1_port" default="/dev/ttyUSB0" />
  <arg name="tag2_port" default="/dev/ttyACM0" />
  <arg name="auto_detect_uwb_ports" default="false" />
  <arg name="tag2_is_front" default="true" />
  <arg name="uwb_height_diff" default="0.72" />
  <arg name="tag_distance" default="0.172" />
  <arg name="tag1_offset" default="[0.072366, 0.085274, -0.219662]" />
  <arg name="tag2_offset" default="[-0.260363, -0.241691, 0.066048]" />
  <arg name="imu_topic" default="/imu" />
  <arg name="odom_topic" default="/odom" />
  <arg name="heading_source" default="initial_imu" />
  <arg name="initial_heading_deg" default="-90.0" />
  <arg name="imu_yaw_offset" default="0.0" />
  <arg name="invert_imu_yaw" default="false" />
  <arg name="auto_calibrate_yaw_offset" default="false" />

  <node pkg="turtlebot_charging_project" type="dual_tag_uwb_pose_raw.py" name="dual_tag_uwb_pose_raw" output="screen">
    <param name="port_tag1" value="$(arg tag1_port)" />
    <param name="port_tag2" value="$(arg tag2_port)" />
    <param name="auto_detect_ports" value="$(arg auto_detect_uwb_ports)" />
    <param name="tag2_is_front" value="$(arg tag2_is_front)" />
    <param name="height_diff" value="$(arg uwb_height_diff)" />
    <param name="tag_distance" value="$(arg tag_distance)" />
    <rosparam param="tag1_offset" subst_value="true">$(arg tag1_offset)</rosparam>
    <rosparam param="tag2_offset" subst_value="true">$(arg tag2_offset)</rosparam>
    <param name="max_cost" value="1.06" />
    <rosparam param="anchors">
      - [0.0, 0.0]
      - [5.0, 0.0]
      - [5.0, 5.0]
    </rosparam>
  </node>

  <node pkg="turtlebot_charging_project" type="uwb_imu_pose_publisher.py" name="uwb_imu_pose_publisher" output="screen">
    <param name="uwb_pose_raw_topic" value="/uwb/pose_raw" />
    <param name="imu_topic" value="$(arg imu_topic)" />
    <param name="odom_topic" value="$(arg odom_topic)" />
    <param name="heading_source" value="$(arg heading_source)" />
    <param name="initial_heading_deg" value="$(arg initial_heading_deg)" />
    <param name="imu_yaw_offset" value="$(arg imu_yaw_offset)" />
    <param name="invert_imu_yaw" value="$(arg invert_imu_yaw)" />
    <param name="auto_calibrate_yaw_offset" value="$(arg auto_calibrate_yaw_offset)" />
    <param name="auto_calibrate_sample_count" value="20" />
    <param name="auto_calibrate_min_resultant" value="0.70" />
    <param name="auto_calibrate_max_position_std" value="0.35" />
    <param name="uwb_timeout" value="10.0" />
    <param name="allow_stale_uwb" value="true" />
    <param name="max_stale_uwb_age" value="30.0" />
    <param name="use_odom_prediction" value="true" />
    <param name="odom_timeout" value="0.5" />
    <param name="max_prediction_dt" value="0.20" />
    <param name="uwb_correction_alpha" value="0.45" />
    <param name="heading_correction_alpha" value="0.35" />
    <param name="imu_timeout" value="1.0" />
    <param name="room_min_x" value="0.0" />
    <param name="room_max_x" value="5.0" />
    <param name="room_min_y" value="0.0" />
    <param name="room_max_y" value="5.0" />
    <param name="pose_bounds_margin" value="0.10" />
    <param name="boundary_clamp_margin" value="0.0" />
    <param name="invalid_origin_radius" value="0.12" />
    <param name="max_pose_jump" value="0.80" />
    <param name="require_pose_stability" value="true" />
  </node>
</launch>
