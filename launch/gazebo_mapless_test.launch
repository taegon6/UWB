<launch>
  <arg name="model" default="waffle_pi" />
  <arg name="gui" default="true" />
  <arg name="default_charger_id" default="1" />

  <env name="TURTLEBOT3_MODEL" value="$(arg model)" />

  <include file="$(find turtlebot3_gazebo)/launch/turtlebot3_empty_world.launch">
    <arg name="world_name" value="$(find turtlebot_charging_project)/worlds/mapless_charging_test.world" />
    <arg name="gui" value="$(arg gui)" />
  </include>

  <node pkg="turtlebot_charging_project" type="sim_uwb_pose_from_odom.py" name="sim_uwb_pose_from_odom" output="screen">
    <param name="position_noise_std" value="0.02" />
    <param name="yaw_noise_std" value="0.01" />
  </node>

  <node pkg="turtlebot_charging_project" type="charger_target_selector.py" name="charger_target_selector" output="screen">
    <param name="default_charger_id" value="$(arg default_charger_id)" />
    <rosparam param="chargers">
      - [1, 3.8, 1.2]
      - [2, 3.8, -1.2]
    </rosparam>
  </node>

  <include file="$(find turtlebot_charging_project)/launch/lidar_local_planner.launch" />
</launch>
